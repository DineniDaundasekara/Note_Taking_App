# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Replace with your local URI or MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/notara

# Authentication
# Generous secret key for JWT signing
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRE=7d

# CORS Configuration
# Used in production to restrict access to specific client URL
CLIENT_URL=http://localhost:5173
